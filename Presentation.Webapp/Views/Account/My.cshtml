@model MyAccountViewModel

@{
    ViewData["Title"] = "My Account";
}

<div class="container">
    <partial name="Partials/Globals/_PageTitleSection"/>

    <section class="my-account-section">
        <aside class="my-account-sidebar">
            <section class="profile-image-section">
                <img src="~/images/my-account-profilepicture-1.png" />
            </section>
            <section class="menu-options-section">
                <div class="menu-header">
                    <h3>Menu Options</h3>
                </div>
                <button class="profile-menu-button">About Me</button>
                <button class="profile-menu-button">My Membership</button>
                <button class="profile-menu-button">My Bookings</button>
                <form asp-action="SignOut" asp-controller="Authentication" method="post">
                    <button type="submit" class="profile-menu-button" style="width: 100%; text-align: left;">Sign Out</button>
                </form>
            </section>
            <p>If you like to cancel your account click below</p>
            <a class="warning-text">Remove Account</a>
        </aside>

        <section class="about-me-form-section">
            <form class="about-me-form" asp-action="My" asp-controller="Account" method="post" novalidate>
                <h2 class="title">About Me</h2>
                <hr/>

                @if (!string.IsNullOrWhiteSpace(ViewData["Message"]?.ToString()))
                {
                    if (ViewData["MessageType"]?.ToString() == "error")
                    {
                        <div class="error-message">
                            <p>@ViewData["Message"]</p>
                        </div>
                    }
                    else
                    {
                        <div class="success-message">
                            <p>@ViewData["Message"]</p>
                        </div>
                    }
                }
                <div class="form-group">
                    <label class="form-label" asp-for="AboutMeForm.FirstName"></label>
                    <input class="form-input" asp-for="AboutMeForm.FirstName"/>
                    <span class="field-validation-error" asp-validation-for="AboutMeForm.FirstName"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="AboutMeForm.LastName"></label>
                    <input class="form-input" asp-for="AboutMeForm.LastName" />
                    <span class="field-validation-error" asp-validation-for="AboutMeForm.LastName"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Email"></label>
                    <input class="form-input" asp-for="Email" disabled/>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="AboutMeForm.PhoneNumber"></label>
                    <input class="form-input" asp-for="AboutMeForm.PhoneNumber" />
                    <span class="field-validation-error" asp-validation-for="AboutMeForm.PhoneNumber"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="AboutMeForm.ProfileImageUrl"></label>
                    <div class="file-input-group">
                        <input class="form-input" asp-for="AboutMeForm.ProfileImageUrl" />
                        <button type="button" class="browse-btn" onclick="document.getElementById('profileImageUpload').click()">Browse</button>
                        <input type="file" id="profileImageUpload" accept="image/*" style="display: none;" onchange="updateProfileImageUrl(this)" />
                    </div>
                    <span class="field-validation-error" asp-validation-for="AboutMeForm.ProfileImageUrl"></span>
                </div>
                
                <div class="form-button-placement">
                    <button class="form-button" type="submit">Save</button>
                </div>
            </form>
        </section>



    </section>


</div>