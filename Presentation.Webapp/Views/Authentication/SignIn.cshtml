@model SignInForm

@{
    Layout = "Layouts/_AuthLayout";
    ViewData["Title"] = "Sign In";
}

<section class="auth-section">

    <form class="auth-form" asp-action="SignIn" asp-controller="Authentication" method="post" novalidate>
        @Html.AntiForgeryToken()

        <h1 class="title">Welcome Back!</h1>
        <p class="information">Log in to continue your fitness journey with full access to your customized program, training history, and progress tracking. Stay consistent, monitor your development, and keep moving forward with the structure and support built into your account.</p>
        <hr/>

        <div class="form-group">
            <label class="form-label" asp-for="Email">Enter your credentials</label>
            <input class="form-input" asp-for="Email"/>
        </div>
        <div class="form-group">
            <a class="forgot-password" asp-action="ForgotPassword" asp-controller="Authentication">Forgot your password?</a>
            <input class="form-input" asp-for="Password" />
        </div>

        <div class="form-group checkbox">
            <label class="custom-checkbox">
                <input type="checkbox" asp-for="RememberMe"/>
                <span class="checkmark"></span>
            </label>
            <label class="form-label checkbox" asp-for="RememberMe">Remember me</label>
        </div>

        <button class="form-button" type="submit">Continue</button>

        @if (!string.IsNullOrWhiteSpace(ViewData["ErrorMessage"]?.ToString()))
        {
            <p class="additional-information">
                @ViewData["ErrorMessage"]
            </p>
        }
        <p class="additional-information">
            Not a member? <a asp-action="SignUp" asp-controller="Authentication">Become One</a>
        </p>
    </form>
</section>