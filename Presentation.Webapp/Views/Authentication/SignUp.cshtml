@model RegisterEmailForm

@{
    Layout = "Layouts/_AuthLayout";
    ViewData["Title"] = "Become a Member";

}

<section class="auth-section">

    <form class="auth-form" asp-action="SignUp" asp-controller="Authentication" method="post" novalidate>
        <h1 class="title">Become a Member</h1>
        <p class="information">Sign up to continue your fitness journey with full access to your customized program, training history, and p</p>
        <hr/>
        <div class="form-group">
            <label class="form-label" asp-for="Email"></label>
            <input class="form-input" asp-for="Email"/>
            <span class="field-validation-error" asp-validation-for="Email"></span>
        </div>
        <button class="form-button" type="submit">Continue</button>
        <div class="additional-information">
            <p>We will send a verification code to your Email address.</p>
        </div>
    
    </form>

</section>

@section Scripts {
    <partial name="_ValidationScripts"/>
}